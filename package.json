{
  "name": "@michaelvanlaar/proof-of-thought",
  "version": "0.1.0",
  "description": "TypeScript port of ProofOfThought - Neurosymbolic program synthesis combining LLMs with Z3 theorem proving",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "development": "./dist/browser.js",
      "production": "./dist/browser.min.js",
      "import": "./dist/browser.js",
      "default": "./dist/browser.min.js"
    },
    "./backends": {
      "types": "./dist/backends/index.d.ts",
      "import": "./dist/backends/index.js",
      "require": "./dist/backends/index.cjs"
    },
    "./utils/performance": {
      "types": "./dist/utils/performance.d.ts",
      "import": "./dist/utils/performance.js"
    },
    "./utils/cache": {
      "types": "./dist/utils/cache.d.ts",
      "import": "./dist/utils/cache.js"
    },
    "./utils/batching": {
      "types": "./dist/utils/batching.d.ts",
      "import": "./dist/utils/batching.js"
    },
    "./utils/z3-config": {
      "types": "./dist/utils/z3-config.d.ts",
      "import": "./dist/utils/z3-config.js"
    },
    "./utils/lazy-loader": {
      "types": "./dist/utils/lazy-loader.d.ts",
      "import": "./dist/utils/lazy-loader.js"
    },
    "./utils/wasm-loader": {
      "types": "./dist/utils/wasm-loader.d.ts",
      "import": "./dist/utils/wasm-loader.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "npm run build:types && npm run build:bundle",
    "build:types": "tsc --emitDeclarationOnly",
    "build:bundle": "node scripts/build.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,md}\"",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "benchmark": "tsx benchmarks/cli.ts",
    "benchmark:compare": "tsx benchmarks/compare.ts",
    "prepare": "husky install || true",
    "prepublishOnly": "npm run clean && npm run build && npm run test",
    "ci": "npm run lint && npm run typecheck && npm run test:coverage && npm run build",
    "validate": "npm run lint && npm run typecheck && npm run test"
  },
  "keywords": [
    "neurosymbolic",
    "reasoning",
    "llm",
    "z3",
    "z3-solver",
    "theorem-proving",
    "formal-verification",
    "smt",
    "smt2",
    "smt-lib",
    "ai",
    "artificial-intelligence",
    "logic",
    "first-order-logic",
    "symbolic-reasoning",
    "proof-of-thought",
    "openai",
    "gpt-4",
    "language-model",
    "automated-reasoning",
    "program-synthesis",
    "typescript",
    "nodejs",
    "browser"
  ],
  "author": "Michael van Laar <michael@van-laar.de>",
  "contributors": [
    {
      "name": "Debargha Ganguly",
      "url": "https://github.com/DebarghaG"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MichaelvanLaar/proof-of-thought.git"
  },
  "bugs": {
    "url": "https://github.com/MichaelvanLaar/proof-of-thought/issues"
  },
  "homepage": "https://github.com/MichaelvanLaar/proof-of-thought#readme",
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "openai": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "openai": {
      "optional": false
    }
  },
  "dependencies": {
    "openai": "^4.0.0",
    "z3-solver": "^4.12.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.1",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "commander": "^14.0.2",
    "esbuild": "^0.25.0",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "express": "^5.2.1",
    "husky": "^9.1.7",
    "prettier": "^3.4.2",
    "tsx": "^4.20.6",
    "typescript": "^5.7.2",
    "vitest": "^3.0.4"
  }
}
